# GoBuildMe - Ignore most of .gobuildme, preserve key directories
# The .gobuildme directory contains auto-generated specs and working files
# Only memory/ and docs/ should be committed (project constitution and docs)
.gobuildme/*
!.gobuildme/memory
!.gobuildme/docs

# Agent commands (auto-generated by gobuildme init)
# Markdown-based agents
.claude/commands/gbm.*
.claude/commands/help.md
.github/prompts/gbm.*
.github/prompts/help.md
.cursor/commands/gbm.*
.cursor/commands/help.md
.codex/prompts/gbm.*
.codex/prompts/help.md
.windsurf/workflows/gbm.*
.windsurf/workflows/help.md
.amazonq/prompts/gbm.*
.amazonq/prompts/help.md
.augment/commands/gbm.*
.augment/commands/help.md
.opencode/command/gbm.*
.opencode/command/help.md
.kilocode/workflows/gbm.*
.kilocode/workflows/help.md
.roo/commands/gbm.*
.roo/commands/help.md
# TOML-based agents
.gemini/commands/gbm.*
.gemini/commands/help.toml
.qwen/commands/gbm.*
.qwen/commands/help.toml

# Common patterns (customize for your project)
.DS_Store
*.log
.env
.env.local

